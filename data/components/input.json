      "aria": { "label": "ARIA", "code": "<div role=\"textbox\"\n  aria-label=\"이름\"\n  contenteditable=\"true\"\n  tabindex=\"0\"></div>", "desc": "role=\"textbox\" 사용 시 폼 제출/유효성 검사 직접 구현", "descType": "warn" }
