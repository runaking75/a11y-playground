    "roles": [
      { "role": "textbox", "attr": "", "element": "div", "desc": ["요소를 텍스트 입력 필드로 식별", "contenteditable과 함께 사용"] },
      { "role": "", "attr": "aria-errormessage=\"ID\"", "element": "input", "desc": ["오류 메시지 요소와 연결", "aria-invalid=\"true\"와 함께 사용"] }
