    "defaultVariant": "default",
    "previewHtml": "<div class=\"ap-preview__label\">DEFAULT</div><div class=\"ap-preview__row\" style=\"flex-direction:column;align-items:stretch;max-width:320px;width:100%\"><div class=\"input-field\" data-component=\"input\"><label class=\"input-label\" for=\"demo-name\">이름</label><input type=\"text\" class=\"input\" id=\"demo-name\" placeholder=\"이름을 입력하세요\"></div><div class=\"input-field\" data-component=\"input\"><label class=\"input-label\" for=\"demo-email\">이메일 <span class=\"input-required\">*</span></label><input type=\"email\" class=\"input\" id=\"demo-email\" placeholder=\"email@example.com\" aria-required=\"true\"></div></div><div class=\"ap-preview__label\">STATES</div><div class=\"ap-preview__row\" style=\"flex-direction:column;align-items:stretch;max-width:320px;width:100%\"><div class=\"input-field\" data-component=\"input\"><label class=\"input-label\" for=\"demo-err\">전화번호</label><input type=\"tel\" class=\"input input--error\" id=\"demo-err\" value=\"abc\" aria-invalid=\"true\" aria-errormessage=\"err-msg\"><span class=\"input-error\" id=\"err-msg\">올바른 전화번호를 입력하세요</span></div><div class=\"input-field\" data-component=\"input\"><label class=\"input-label\" for=\"demo-dis\">비활성화</label><input type=\"text\" class=\"input\" id=\"demo-dis\" disabled value=\"수정 불가\"></div></div>",
