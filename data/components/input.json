        "do": { "code": "<label for=\"email\">이메일</label>\n<input type=\"email\" id=\"email\"\n  autocomplete=\"email\">", "image": "", "note": "label 연결 + autocomplete로 입력 목적 명시" },
        "dont": { "code": "<input type=\"text\" placeholder=\"이메일\">", "image": "", "comment": "label 없음, placeholder만 사용", "note": "placeholder는 레이블을 대체할 수 없습니다. 입력 시 사라져 사용자가 목적을 잊을 수 있습니다." }
      }
    ],
    "checklist": [
      "모든 입력 필드에 <code>&lt;label&gt;</code> 연결",
