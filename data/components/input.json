      { "std": "wcag", "stdLabel": "WCAG 2.2", "item": "SC 3.3.1 오류 식별", "desc": "오류 발생 시 텍스트로 설명 제공", "level": "A" },
      { "std": "wcag", "stdLabel": "WCAG 2.2", "item": "SC 1.3.5 입력 목적 식별", "desc": "autocomplete 속성으로 입력 목적 제공", "level": "AA" }
