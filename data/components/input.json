  "code": {
    "filename": "input.html",
    "snippets": [
      { "label": "기본 텍스트 입력", "code": "<label for=\"name\">이름</label>\n<input type=\"text\" id=\"name\">" },
      { "label": "필수 + 힌트", "code": "<label for=\"pwd\">비밀번호</label>\n<input type=\"password\" id=\"pwd\"\n  aria-required=\"true\"\n  aria-describedby=\"pwd-hint\">\n<span id=\"pwd-hint\">8자 이상, 특수문자 포함</span>" },
      { "label": "오류 상태", "code": "<label for=\"tel\">전화번호</label>\n<input type=\"tel\" id=\"tel\"\n  aria-invalid=\"true\"\n  aria-errormessage=\"tel-err\">\n<span id=\"tel-err\" role=\"alert\">\n  올바른 전화번호를 입력하세요\n</span>" }
    ]
  }
