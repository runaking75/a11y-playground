    "snippets": [
      {
        "label": "기본 메뉴 버튼",
        "code": "<button aria-haspopup=\"true\"\n  aria-expanded=\"false\"\n  aria-controls=\"action-menu\">\n  동작 ▾\n</button>\n<ul role=\"menu\" id=\"action-menu\" hidden>\n  <li role=\"menuitem\" tabindex=\"-1\">편집</li>\n  <li role=\"menuitem\" tabindex=\"-1\">복사</li>\n  <li role=\"menuitem\" tabindex=\"-1\">삭제</li>\n</ul>"
      },
      {
        "label": "구분선 포함 메뉴",
        "code": "<button aria-haspopup=\"true\"\n  aria-expanded=\"false\"\n  aria-controls=\"file-menu\">\n  파일 ▾\n</button>\n<ul role=\"menu\" id=\"file-menu\" hidden>\n  <li role=\"menuitem\" tabindex=\"-1\">새 파일</li>\n  <li role=\"menuitem\" tabindex=\"-1\">열기</li>\n  <li role=\"separator\"></li>\n  <li role=\"menuitem\" tabindex=\"-1\">저장</li>\n  <li role=\"menuitem\" tabindex=\"-1\">다른 이름으로 저장</li>\n</ul>"
      },
      {
        "label": "아이콘 전용 메뉴 버튼",
        "code": "<button aria-haspopup=\"true\"\n  aria-expanded=\"false\"\n  aria-controls=\"more-menu\"\n  aria-label=\"더보기\">\n  <svg aria-hidden=\"true\">...</svg>\n</button>\n<ul role=\"menu\" id=\"more-menu\" hidden>\n  <li role=\"menuitem\" tabindex=\"-1\">공유</li>\n  <li role=\"menuitem\" tabindex=\"-1\">링크 복사</li>\n  <li role=\"menuitem\" tabindex=\"-1\" aria-disabled=\"true\">삭제</li>\n</ul>"
      },
      {
        "label": "체크 가능한 메뉴 항목",
        "code": "<button aria-haspopup=\"true\"\n  aria-expanded=\"false\"\n  aria-controls=\"view-menu\">\n  보기 옵션 ▾\n</button>\n<ul role=\"menu\" id=\"view-menu\" hidden>\n  <li role=\"menuitemcheckbox\"\n    aria-checked=\"true\" tabindex=\"-1\">격자 표시</li>\n  <li role=\"menuitemcheckbox\"\n    aria-checked=\"false\" tabindex=\"-1\">미리보기</li>\n</ul>"
      }
    ]
  }
