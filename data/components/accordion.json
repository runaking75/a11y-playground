    "doDont": [
      {
        "do": {
          "code": "<h3>\n  <button aria-expanded=\"false\"\n    aria-controls=\"sect1\">\n    섹션 제목\n  </button>\n</h3>\n<div id=\"sect1\" role=\"region\"\n  aria-labelledby=\"hdr1\" hidden>\n  <p>내용</p>\n</div>",
          "image": "",
          "note": "헤딩 안에 button 사용, aria-expanded + aria-controls 적용"
        },
        "dont": {
          "code": "<div class=\"header\"\n  onclick=\"toggle()\">\n  섹션 제목\n</div>\n<div class=\"panel\"\n  style=\"display:none\">\n  <p>내용</p>\n</div>",
          "image": "",
          "comment": "button 없음, ARIA 속성 누락, 키보드 접근 불가",
          "note": "div에 클릭 이벤트만 사용하면 키보드 접근 불가, 스크린리더가 상태를 인식할 수 없습니다."
        }
      }
    ],
    "checklist": [
      {
        "text": "헤더에 <code>&lt;button&gt;</code> 사용",
        "sc": "SC 4.1.2",
        "solution": "<code>&lt;h3&gt;&lt;button aria-expanded=\"false\" aria-controls=\"패널id\"&gt;</code> 구조"
      },
      {
        "text": "<code>aria-expanded</code>로 열림/닫힘 상태 전달",
        "sc": "SC 4.1.2",
        "solution": "열림=<code>aria-expanded=\"true\"</code>, 닫힘=<code>false</code>. 토글 시 동적 변경"
      },
      {
        "text": "<code>aria-controls</code>로 헤더-패널 연결",
        "sc": "SC 1.3.1",
        "solution": "패널에 id 부여 → 헤더 버튼에 <code>aria-controls=\"패널id\"</code>"
      },
      {
        "text": "<kbd>Enter</kbd>/<kbd>Space</kbd>로 열기/닫기",
        "sc": "SC 2.1.1",
        "solution": "네이티브 <code>&lt;button&gt;</code> 사용하면 자동 지원"
      },
      {
        "text": "패널에 <code>role=\"region\"</code> + <code>aria-labelledby</code>",
        "sc": "SC 4.1.2",
        "solution": "패널에 <code>role=\"region\"</code> + <code>aria-labelledby=\"헤더버튼id\"</code>로 연결"
      }
    ],
