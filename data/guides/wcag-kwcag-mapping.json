{
  "id": "wcag-kwcag-mapping",
  "type": "mapping",
  "title": "WCAG 2.2 ↔ KWCAG 2.2 매핑",
  "source": "https://www.w3.org/TR/WCAG22/",
  "updated": "2026-03",
  "overview": {
    "desc": "W3C 국제 표준(WCAG 2.2)과 한국형 웹 콘텐츠 접근성 지침(KWCAG 2.2)의 성공 기준을 1:1로 매핑하고, 차이점과 실무 적용 시 주의사항을 정리합니다.",
    "structure": "WCAG 86개 SC ↔ KWCAG 33개 검사항목",
    "meta": [
      {
        "label": "WCAG 2.2",
        "value": "4원칙 → 13지침 → 86 성공 기준 (A/AA/AAA)"
      },
      {
        "label": "KWCAG 2.2",
        "value": "4원칙 → 14지침 → 33개 검사항목 (레벨 구분 없이 전부 필수)"
      }
    ]
  },
