{
  "controls": [
    { "type": "select", "attr": "font-family", "label": "폰트", "default": "'Noto Sans KR', sans-serif", "options": [
      { "label": "Noto Sans KR", "value": "'Noto Sans KR', sans-serif" },
      { "label": "시스템 기본", "value": "-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif" },
      { "label": "맑은 고딕", "value": "'Malgun Gothic', '맑은 고딕', sans-serif" },
      { "label": "나눔고딕", "value": "'NanumGothic', sans-serif" },
      { "label": "Pretendard", "value": "'Pretendard', sans-serif" },
      { "label": "Roboto", "value": "'Roboto', sans-serif" },
      { "label": "Arial", "value": "Arial, Helvetica, sans-serif" },
      { "label": "serif", "value": "'Noto Serif KR', Georgia, serif" },
      { "label": "monospace", "value": "'Fira Code', monospace" }
    ]},
    { "type": "slider", "attr": "font-size", "label": "폰트 사이즈", "min": 12, "max": 36, "default": 14, "unit": "px", "step": 1 },
    { "type": "slider", "attr": "line-height", "label": "라인하이트", "min": 1.0, "max": 2.5, "default": 1.5, "unit": "", "step": 0.1 },
    { "type": "slider", "attr": "font-weight", "label": "폰트 웨이트", "min": 300, "max": 700, "default": 500, "unit": "", "step": 100 },
    { "type": "slider", "attr": "padding-block", "label": "패딩 (상하)", "min": 0, "max": 24, "default": 10, "unit": "px", "step": 1 },
    { "type": "slider", "attr": "padding-inline", "label": "패딩 (좌우)", "min": 0, "max": 40, "default": 24, "unit": "px", "step": 1 },
    { "type": "slider", "attr": "border-radius", "label": "라운드", "min": 0, "max": 24, "default": 8, "unit": "px", "step": 1 }
  ],
  "colorPickers": [
    { "label": "배경색", "attr": "background-color", "default": "#2563EB" },
    { "label": "텍스트색", "attr": "color", "default": "#FFFFFF" },
    { "label": "테두리색", "attr": "border-color", "default": "#93C5FD" }
  ]
}
